{
  "version": 1,
  "requiredFiles": [
    "docs/team-standards/README.md",
    "docs/team-standards/generation.md",
    "docs/team-standards/refactoring.md",
    "docs/team-standards/security.md",
    "docs/team-standards/review.md",
    "docs/team-standards/calibration.md",
    "docs/team-standards/har-rule-coverage.json",
    "docs/team-standards/har-rule-examples.json"
  ],
  "forbiddenPatterns": [
    "~/.cursor",
    "~/.codex"
  ],
  "instructionTemplate": {
    "files": [
      "docs/team-standards/generation.md",
      "docs/team-standards/refactoring.md",
      "docs/team-standards/security.md",
      "docs/team-standards/review.md"
    ],
    "maxLines": 180,
    "requiredHeadings": [
      "## Role Definition",
      "## Context Requirements",
      "## Categorized Standards",
      "## Output Format",
      "## Scope Boundary"
    ],
    "requiredSubheadings": [
      "### Critical",
      "### Important",
      "### Advisory"
    ],
    "requiredPhrases": [
      "Single purpose"
    ]
  },
  "readme": {
    "requiredHeadings": [
      "# Team Standards Instructions",
      "## Purpose",
      "## Instruction Set",
      "## Calibration",
      "## Validation"
    ],
    "requiredMentions": [
      "`generation.md`",
      "`refactoring.md`",
      "`security.md`",
      "`review.md`",
      "`calibration.md`",
      "`har-rule-coverage.json`",
      "`har-rule-examples.json`",
      "pnpm standards:check"
    ]
  },
  "calibration": {
    "file": "docs/team-standards/calibration.md",
    "requiredHeadings": [
      "# Team Standards Calibration",
      "## Cadence",
      "## Trigger Signals",
      "## Calibration Steps",
      "## History"
    ],
    "historyEntryPattern": "\\d{4}-\\d{2}-\\d{2}:",
    "historyMinimumEntries": 1,
    "warningAfterDays": 31,
    "failAfterDays": 45
  },
  "harRuleCoverage": {
    "visionContractFile": "docs/strategy/vision-contract.json",
    "catalogSourceFile": "packages/harness/src/rules/har-catalog.ts",
    "matrixFile": "docs/team-standards/har-rule-coverage.json",
    "requiredEntryKeys": [
      "ruleId",
      "templateTarget",
      "standardFiles",
      "summary"
    ]
  },
  "harExamples": {
    "file": "docs/team-standards/har-rule-examples.json",
    "requiredEntryKeys": [
      "ruleId",
      "examples"
    ],
    "requiredExampleKeys": [
      "path",
      "kind",
      "summary"
    ],
    "allowedKinds": [
      "test",
      "doc",
      "code"
    ]
  },
  "report": {
    "path": "docs/team-standards/reports/latest.json",
    "historyDir": "docs/team-standards/reports/history",
    "historyIndexPath": "docs/team-standards/reports/history/index.json",
    "version": 1,
    "requiredTopLevelKeys": [
      "version",
      "generatedBy",
      "currentPhase",
      "status",
      "counts",
      "failures",
      "warnings",
      "passes"
    ],
    "historyRequiredTopLevelKeys": [
      "version",
      "generatedBy",
      "retention",
      "entries"
    ],
    "retention": {
      "maxEntries": 60,
      "maxAgeDays": 120
    }
  }
}
