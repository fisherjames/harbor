# Harbor runtime model provider
# Use "openai" for real LLM runs, or "echo" for deterministic local dry-runs.
HARBOR_MODEL_PROVIDER=openai
OPENAI_API_KEY=
HARBOR_OPENAI_MODEL=gpt-4.1-mini
HARBOR_OPENAI_BASE_URL=https://api.openai.com/v1
HARBOR_OPENAI_TIMEOUT_MS=20000
HARBOR_OPENAI_RETRIES=2
HARBOR_OPENAI_RETRY_JITTER_MS=120
HARBOR_OPENAI_TEMPERATURE=0.2

# memU (managed) - optional for local bootstrap
MEMU_ENDPOINT=
MEMU_API_KEY=
MEMU_SIGNING_SECRET=

# Persistence (optional: falls back to in-memory stores when unset)
DATABASE_URL=
HARBOR_RUN_ISOLATION_MODE=git-worktree

# Inference gate configuration
HARBOR_INFERENCE_GATE_MODE=report
HARBOR_INFERENCE_MODEL=gpt-4.1-mini
HARBOR_INFERENCE_TIMEOUT_MS=25000
HARBOR_INFERENCE_RETRIES=2
HARBOR_INFERENCE_RETRY_JITTER_MS=150
HARBOR_INFERENCE_MAX_CHARS=6000

# Set to your provider pricing for accurate cost estimation in inference reports
HARBOR_INFERENCE_INPUT_COST_PER_1K=0.0004
HARBOR_INFERENCE_OUTPUT_COST_PER_1K=0.0016
