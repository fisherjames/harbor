{
  "name": "harbor",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "vision:check": "node ./scripts/vision-drift-check.mjs",
    "clean": "turbo run clean",
    "check": "pnpm vision:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "turbo": "^2.5.0",
    "typescript": "^5.9.0",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.6"
  }
}
