# Copy to .env (or export in shell) before `docker compose up --build`.
# OpenAI
HARBOR_MODEL_PROVIDER=openai
OPENAI_API_KEY=
HARBOR_OPENAI_MODEL=gpt-4.1-mini
HARBOR_OPENAI_BASE_URL=https://api.openai.com/v1
HARBOR_OPENAI_TIMEOUT_MS=20000
HARBOR_OPENAI_RETRIES=2
HARBOR_OPENAI_RETRY_JITTER_MS=120
HARBOR_OPENAI_TEMPERATURE=0.2

# Harbor runtime dependencies (defaults in compose, listed for explicitness)
DATABASE_URL=postgres://harbor:harbor@postgres:5432/harbor
MEMU_ENDPOINT=http://memu-mock:8080
MEMU_API_KEY=
MEMU_SIGNING_SECRET=

# Optional GitHub promotion provider wiring
GITHUB_TOKEN=
GITHUB_PROMOTION_REPOSITORY=
GITHUB_PROMOTION_BRANCH=
GITHUB_PROMOTION_BASE_BRANCH=
GITHUB_PROMOTION_SHA=
GITHUB_PROMOTION_PR_NUMBER=

# Optional Clerk browser auth key for local UI auth surfaces
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Optional stuck-run watchdog tuning
HARBOR_STUCK_RUN_STALE_AFTER_SECONDS=900
HARBOR_STUCK_RUN_SCAN_LIMIT=100
HARBOR_RUN_ISOLATION_MODE=git-worktree

# Host port overrides (change if local ports are already in use)
HARBOR_WEB_PORT=3000
HARBOR_WORKER_PORT=8289
HARBOR_INNGEST_PORT=8288
HARBOR_POSTGRES_PORT=5432
HARBOR_REDIS_PORT=6379
HARBOR_MEMU_PORT=8081

# Optional policy/runtime controls
HARBOR_POLICY_SIGNING_SECRET=
HARBOR_TRUSTED_POLICY_SIGNATURES=
HARBOR_OBSERVABILITY_SESSION_TTL_MS=900000
OTEL_EXPORTER_OTLP_ENDPOINT=local-inline
