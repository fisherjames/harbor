{
  "name": "@harbor/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -w -p tsconfig.build.json",
    "lint": "echo \"Engine lint is covered by TypeScript + harness runtime checks\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@harbor/harness": "workspace:*",
    "@harbor/memu": "workspace:*",
    "@harbor/observability": "workspace:*"
  }
}
